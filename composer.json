{"name": "paulocarpinetti/phprefactor",
    "description": "Desafios práticos de refatoração de código legado PHP e aplicação de princípios SOLID.",
    "keywords": ["php", "refactoring", "solid", "design-patterns", "phpunit", "clean-code"],
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Paulo Carpinetti",
            "email": "pauloscarpinetti@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-text",
        "clear": [
            "composer dump-autoload",
            "vendor/bin/phpunit --clear-cache"
        ]
    }
}
